<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/input"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".HealthInputActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="개선하고 싶은 부분을\n순서대로 골라주세요"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="최대 3개까지 선택할 수 있어요."
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="건강검진 항목 관련"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_health_checkup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_liver"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="간 건강"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_fatigue"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="활력/피로"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_body_fat"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="체지방 관리"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_cholesterol"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="콜레스테롤"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_blood_sugar"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="혈당 관리"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_blood_pressure"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="혈압 관리"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="주요 장기 관련"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_organs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_brain"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="뇌 건강"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_eye"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="눈 건강"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_bone"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="뼈 건강"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_stomach"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="위 건강"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_intestine"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="장 건강"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="일상 생활 관련"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_daily_life"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_joint_muscle"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="관절/근육"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_immunity"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="면역력"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_hair_nail"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="모발/손톱"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_sleep"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="수면"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_stress"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="스트레스"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_anti_aging"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="항노화/항산화"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_skin"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="피부"
            app:chipBackgroundColor="@color/chip_background_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1dp"
            app:checkedIconEnabled="false"
            android:textColor="@color/chip_text_selector"/>

    </com.google.android.material.chip.ChipGroup>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/> <Button
    android:id="@+id/submitButton"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="0개 선택 완료"
    android:textSize="18sp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:backgroundTint="@color/green_button_selector"
    android:textColor="@color/white"
    android:enabled="false"/> </LinearLayout>